// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Invitee {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  email          String?        @unique
  phone          String?
  listType       ListType       @default(PAGANTE) // PAGANTE o GREEN
  paymentType    String?        // Solo per PAGANTE: bonifico, paypal, contanti, p2p
  hasEntered     Boolean        @default(false) // true = entrato (rosso), false = non entrato (verde)
  checkedInAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  checkInLogs    CheckInLog[]

  @@index([lastName, firstName])
}

model CheckInLog {
  id         String        @id @default(cuid())
  outcome    CheckInStatus
  message    String?
  inviteeId  String?
  invitee    Invitee?      @relation(fields: [inviteeId], references: [id])
  createdAt  DateTime      @default(now())
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  password     String       // Hashed password
  role         UserRole     @default(ENTRANCE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model SystemConfig {
  id           Int          @id @default(autoincrement())
  eventName    String       @default("Ingresso Festa")
  eventStatus  EventStatus  @default(ACTIVE)
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())
}

enum ListType {
  PAGANTE
  GREEN
}

enum UserRole {
  ADMIN
  ENTRANCE
}

enum CheckInStatus {
  SUCCESS
  DUPLICATE
  BLOCKED
}

enum EventStatus {
  ACTIVE
  PAUSED
  LOCKED
}
