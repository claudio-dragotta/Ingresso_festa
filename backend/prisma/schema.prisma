// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===================== EVENTI =====================

model Event {
  id            String       @id @default(cuid())
  name          String
  date          DateTime?
  googleSheetId String?
  // JSON array dei moduli attivi: ["tshirts", "expenses", "shuttles"]
  modules       String       @default("[]")
  status        EventStatus  @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  invitees        Invitee[]
  checkInLogs     CheckInLog[]
  tshirts         Tshirt[]
  expenses        Expense[]
  shuttleMachines ShuttleMachine[]
  shuttleSlots    ShuttleSlot[]
  userAccess      UserEventAccess[]
}

// Assegna un utente a una festa con un ruolo specifico
model UserEventAccess {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  role      UserRole
  createdAt DateTime @default(now())

  @@unique([userId, eventId])
}

// ===================== INVITATI =====================

model Invitee {
  id             String         @id @default(cuid())
  eventId        String
  event          Event          @relation(fields: [eventId], references: [id])
  firstName      String
  lastName       String
  listType       ListType       @default(PAGANTE)
  paymentType    String?
  email          String?
  qrToken        String?        @unique
  qrSentAt       DateTime?
  hasEntered     Boolean        @default(false)
  checkedInAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  checkInLogs    CheckInLog[]
  shuttleAssignments ShuttleAssignment[] @relation("InviteeShuttleAssignments")

  @@index([eventId, lastName, firstName])
}

model CheckInLog {
  id         String        @id @default(cuid())
  outcome    CheckInStatus
  message    String?
  inviteeId  String?
  invitee    Invitee?      @relation(fields: [inviteeId], references: [id])
  userId     String?
  user       User?         @relation(fields: [userId], references: [id])
  eventId    String?
  event      Event?        @relation(fields: [eventId], references: [id])
  createdAt  DateTime      @default(now())
}

// ===================== UTENTI =====================

model User {
  id           String            @id @default(cuid())
  username     String            @unique
  password     String
  // ADMIN = accesso globale a tutte le feste
  // Gli altri ruoli accedono tramite UserEventAccess
  role         UserRole          @default(ENTRANCE)
  active       Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  checkInLogs  CheckInLog[]
  markedShuttleAssignments ShuttleAssignment[] @relation("UserMarkedShuttleAssignments")
  eventAccess  UserEventAccess[]
}

// ===================== CONFIG DI SISTEMA (legacy, mantenuta per compatibilità) =====================

model SystemConfig {
  id           Int          @id @default(autoincrement())
  eventName    String       @default("Ingresso Festa")
  eventStatus  EventStatus  @default(ACTIVE)
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())
}

// ===================== MAGLIETTE =====================

model Tshirt {
  id           String       @id @default(cuid())
  eventId      String
  event        Event        @relation(fields: [eventId], references: [id])
  firstName    String
  lastName     String
  size         String
  type         String
  hasReceived  Boolean      @default(false)
  receivedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([eventId, lastName, firstName])
  @@index([type])
  @@index([hasReceived])
}

// ===================== SPESE =====================

model Expense {
  id            String          @id @default(cuid())
  eventId       String
  event         Event           @relation(fields: [eventId], references: [id])
  description   String
  amount        Float
  category      ExpenseCategory @default(ALTRO)
  paymentMethod String
  date          DateTime        @default(now())
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([eventId, date])
  @@index([category])
  @@index([paymentMethod])
}

// ===================== NAVETTE =====================

enum ShuttleDirection {
  ANDATA
  RITORNO
}

enum ShuttleBoardStatus {
  PENDING
  BOARDED
  NO_SHOW
}

model ShuttleMachine {
  id          String              @id @default(cuid())
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id])
  name        String
  color       String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assignments ShuttleAssignment[]

  @@unique([name, eventId])
}

model ShuttleSlot {
  id          String              @id @default(cuid())
  eventId     String
  event       Event               @relation(fields: [eventId], references: [id])
  direction   ShuttleDirection
  time        String
  capacity    Int                 @default(12)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assignments ShuttleAssignment[]

  @@unique([direction, time, eventId])
}

model ShuttleAssignment {
  id         String             @id @default(cuid())
  slotId     String
  slot       ShuttleSlot        @relation(fields: [slotId], references: [id])
  machineId  String
  machine    ShuttleMachine     @relation(fields: [machineId], references: [id])
  inviteeId  String?
  invitee    Invitee?           @relation("InviteeShuttleAssignments", fields: [inviteeId], references: [id])
  fullName   String
  status     ShuttleBoardStatus @default(PENDING)
  markedById String?
  markedBy   User?              @relation("UserMarkedShuttleAssignments", fields: [markedById], references: [id])
  markedAt   DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([slotId, machineId])
  @@index([inviteeId])
}

// ===================== ENUM =====================

enum ListType {
  PAGANTE
  GREEN
}

enum ExpenseCategory {
  BEVANDE
  CIBO
  SERVIZI
  DECORAZIONI
  ALTRO
}

enum UserRole {
  ADMIN
  ENTRANCE
  ORGANIZER
  SHUTTLE
}

enum CheckInStatus {
  SUCCESS
  DUPLICATE
  BLOCKED
}

enum EventStatus {
  ACTIVE
  PAUSED
  LOCKED
}
