// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Invitee {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  listType       ListType       @default(PAGANTE) // PAGANTE o GREEN
  paymentType    String?        // Solo per PAGANTE: bonifico, paypal, contanti, p2p
  hasEntered     Boolean        @default(false) // true = entrato (rosso), false = non entrato (verde)
  checkedInAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  checkInLogs    CheckInLog[]

  @@index([lastName, firstName])
}

model CheckInLog {
  id         String        @id @default(cuid())
  outcome    CheckInStatus
  message    String?
  inviteeId  String?
  invitee    Invitee?      @relation(fields: [inviteeId], references: [id])
  userId     String?
  user       User?         @relation(fields: [userId], references: [id])
  createdAt  DateTime      @default(now())
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  password     String       // Hashed password
  role         UserRole     @default(ENTRANCE)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  checkInLogs  CheckInLog[]
}

model SystemConfig {
  id           Int          @id @default(autoincrement())
  eventName    String       @default("Ingresso Festa")
  eventStatus  EventStatus  @default(ACTIVE)
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())
}

model Tshirt {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  size         String       // S, M, L, XL, 2XL, ecc.
  type         String       // "COMPRARE ALTRE", "APPOSTO", "Vincitore", "PR", ecc.
  hasReceived  Boolean      @default(false) // true = consegnata, false = da consegnare
  receivedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([lastName, firstName])
  @@index([type])
  @@index([hasReceived])
}

enum ListType {
  PAGANTE
  GREEN
}

enum UserRole {
  ADMIN
  ENTRANCE
}

enum CheckInStatus {
  SUCCESS
  DUPLICATE
  BLOCKED
}

enum EventStatus {
  ACTIVE
  PAUSED
  LOCKED
}
