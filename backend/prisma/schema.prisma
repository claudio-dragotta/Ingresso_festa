// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Invitee {
  id             String         @id @default(cuid())
  firstName      String
  lastName       String
  listType       ListType       @default(PAGANTE) // PAGANTE o GREEN
  paymentType    String?        // Solo per PAGANTE: bonifico, paypal, contanti, p2p
  hasEntered     Boolean        @default(false) // true = entrato (rosso), false = non entrato (verde)
  checkedInAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  checkInLogs    CheckInLog[]
  shuttleAssignments ShuttleAssignment[] @relation("InviteeShuttleAssignments")

  @@index([lastName, firstName])
}

model CheckInLog {
  id         String        @id @default(cuid())
  outcome    CheckInStatus
  message    String?
  inviteeId  String?
  invitee    Invitee?      @relation(fields: [inviteeId], references: [id])
  userId     String?
  user       User?         @relation(fields: [userId], references: [id])
  createdAt  DateTime      @default(now())
}

model User {
  id           String       @id @default(cuid())
  username     String       @unique
  password     String       // Hashed password
  role         UserRole     @default(ENTRANCE)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  checkInLogs  CheckInLog[]
  markedShuttleAssignments ShuttleAssignment[] @relation("UserMarkedShuttleAssignments")
}

model SystemConfig {
  id           Int          @id @default(autoincrement())
  eventName    String       @default("Ingresso Festa")
  eventStatus  EventStatus  @default(ACTIVE)
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())
}

model Tshirt {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  size         String       // S, M, L, XL, 2XL, ecc.
  type         String       // "COMPRARE ALTRE", "APPOSTO", "Vincitore", "PR", ecc.
  hasReceived  Boolean      @default(false) // true = consegnata, false = da consegnare
  receivedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([lastName, firstName])
  @@index([type])
  @@index([hasReceived])
}

model Expense {
  id            String          @id @default(cuid())
  description   String
  amount        Float
  category      ExpenseCategory @default(ALTRO)
  paymentMethod String          // paypal, contanti, p2p, bonifico - da quale metodo sono stati presi i soldi
  date          DateTime        @default(now())
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([date])
  @@index([category])
  @@index([paymentMethod])
}

// ===================== SHUTTLES =====================

enum ShuttleDirection {
  ANDATA
  RITORNO
}

enum ShuttleBoardStatus {
  PENDING
  BOARDED
  NO_SHOW
}

model ShuttleMachine {
  id          String              @id @default(cuid())
  name        String              @unique
  color       String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assignments ShuttleAssignment[]
}

model ShuttleSlot {
  id          String              @id @default(cuid())
  direction   ShuttleDirection
  time        String              // HH:mm
  capacity    Int                 @default(12)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  assignments ShuttleAssignment[]

  @@unique([direction, time])
}

model ShuttleAssignment {
  id         String             @id @default(cuid())
  slotId     String
  slot       ShuttleSlot        @relation(fields: [slotId], references: [id])
  machineId  String
  machine    ShuttleMachine     @relation(fields: [machineId], references: [id])
  inviteeId  String?
  invitee    Invitee?           @relation("InviteeShuttleAssignments", fields: [inviteeId], references: [id])
  fullName   String
  status     ShuttleBoardStatus @default(PENDING)
  markedById String?
  markedBy   User?              @relation("UserMarkedShuttleAssignments", fields: [markedById], references: [id])
  markedAt   DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([slotId, machineId])
  @@index([inviteeId])
}

enum ListType {
  PAGANTE
  GREEN
}

enum ExpenseCategory {
  BEVANDE
  CIBO
  SERVIZI
  DECORAZIONI
  ALTRO
}

enum UserRole {
  ADMIN
  ENTRANCE
  ORGANIZER
  SHUTTLE
}

enum CheckInStatus {
  SUCCESS
  DUPLICATE
  BLOCKED
}

enum EventStatus {
  ACTIVE
  PAUSED
  LOCKED
}
