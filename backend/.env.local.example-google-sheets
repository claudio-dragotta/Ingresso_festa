# Esempio di configurazione con Google Sheets
# Copia questo file in .env.local e modifica i valori

NODE_ENV=development
PORT=8000
HOST=0.0.0.0

# Database SQLite (usa percorso assoluto su Windows)
DATABASE_URL=file:C:/Users/ludov/Desktop/Ingresso_festa/storage/data/dev.db

# Autenticazione
JWT_SECRET=super-secret-change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password123

# Frontend
FRONTEND_URL=http://localhost:5173

# Storage QR codes
QR_OUTPUT_DIR=../storage/qrcodes

# Email (opzionale)
EMAIL_FROM=festa@example.com
# Esempio Gmail: smtp://tuaemail@gmail.com:tua-app-password@smtp.gmail.com:587
EMAIL_TRANSPORT_URL=

# Dominio pubblico (opzionale)
EVENT_DOMAIN=https://ingresso.example.com

# ============================================================
# GOOGLE SHEETS CONFIGURATION
# ============================================================

# 1. ID del foglio Google Sheets
# Trovalo nella URL: https://docs.google.com/spreadsheets/d/{QUESTO_ID}/edit
# Esempio:
GOOGLE_SHEET_ID=1a2B3c4D5e6F7g8H9i0J1k2L3m4N5o6P7q8R9s0T1u2V3w4X

# 2. Range da leggere (colonna A dal foglio "Lista", dalla riga 2 in poi)
GOOGLE_SHEET_RANGE=Lista!A2:A

# 3. Credenziali Service Account (JSON completo su una riga)
# IMPORTANTE:
# - Copia TUTTO il contenuto del file JSON scaricato da Google Cloud
# - Metti tutto su UNA SOLA RIGA (rimuovi gli a capo)
# - Se hai problemi con i caratteri speciali, usa un editor che supporti stringhe JSON
#
# Esempio (versione RIDOTTA, il tuo sarà molto più lungo):
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"ingresso-festa-123456","private_key_id":"abc123def456","private_key":"-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...(molto lungo)...xyz\n-----END PRIVATE KEY-----\n","client_email":"ingresso-festa-sync@ingresso-festa-123456.iam.gserviceaccount.com","client_id":"1234567890","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/ingresso-festa-sync%40ingresso-festa-123456.iam.gserviceaccount.com"}

# 4. Abilita sincronizzazione automatica
GOOGLE_SHEETS_AUTO_SYNC=true

# 5. Intervallo sincronizzazione in minuti (ogni quanto sincronizzare)
GOOGLE_SHEETS_SYNC_INTERVAL=10

# ============================================================
# NOTE:
# - Consulta GOOGLE_SHEETS_SETUP.md per la guida completa
# - Ricorda di condividere il foglio con l'email del service account
# - L'email del service account è visibile nel JSON: cerca "client_email"
# ============================================================
