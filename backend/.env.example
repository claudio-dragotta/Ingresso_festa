NODE_ENV=development
PORT=8000
HOST=0.0.0.0
# On Windows prefer an absolute path, e.g. file:C:/path/to/Ingresso_festa/storage/data/dev.db
# On macOS/Linux you can keep the relative path below if the CLI runs from backend/
DATABASE_URL=file:../storage/data/dev.db
JWT_SECRET=super-secret-change-me
ADMIN_USERNAME=admin
# Use either the plain password (development only) or a bcrypt hash that starts with b$
ADMIN_PASSWORD=change-me
FRONTEND_URL=http://localhost:5173
QR_OUTPUT_DIR=../storage/qrcodes
EMAIL_FROM=noreply@example.com
# Example: smtp://user:pass@smtp.mailgun.org:587
EMAIL_TRANSPORT_URL=
EVENT_DOMAIN=https://ingresso.example.com

# Google Sheets Integration
# ID del foglio Google (dalla URL: https://docs.google.com/spreadsheets/d/{QUESTO_ID}/edit)
GOOGLE_SHEET_ID=
# Range da leggere (default: Lista!A2:A legge la colonna A dal foglio "Lista" dalla riga 2 in poi)
GOOGLE_SHEET_RANGE=Lista!A2:A
# JSON del Service Account (vedere guida GOOGLE_SHEETS_SETUP.md)
GOOGLE_SERVICE_ACCOUNT_JSON=
# Abilita sincronizzazione automatica
GOOGLE_SHEETS_AUTO_SYNC=true
# Intervallo sincronizzazione in minuti (default: 10)
GOOGLE_SHEETS_SYNC_INTERVAL=10

# Nomi dei tab per le NAVETTE (opzionali, default: "Navette Andata" / "Navette Ritorno")
GOOGLE_SHEET_SHUTTLES_OUTBOUND_NAME=
GOOGLE_SHEET_SHUTTLES_RETURN_NAME=

# ── Invio email QR code ────────────────────────────────
# Mittente: account Gmail da cui vengono inviate le email con i QR code
GMAIL_USER=sesaorganizers@gmail.com
# App Password Gmail (NON la password normale):
#   1. Abilita 2FA su Gmail → account.google.com/security
#   2. Cerca "App password" → genera una password di 16 caratteri
#   3. Incollala qui (senza spazi)
GMAIL_APP_PASSWORD=
